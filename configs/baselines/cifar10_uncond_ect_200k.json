{
  "name": "cifar10_uncond_ect_200k",
  "description": "Official run_ecm.sh protocol. Unconditional CIFAR-10 ECT at batch 128.",
  "conditioning": "unconditional",
  "dataset": "datasets/cifar10-32x32.zip",
  "transfer": "checkpoints/edm-cifar10-32x32-uncond-vp.pkl",
  "transfer_url": "https://nvlabs-fi-cdn.nvidia.com/edm/pretrained/edm-cifar10-32x32-uncond-vp.pkl",
  "arch": "ddpmpp",
  "precond": "ect",
  "batch": 128,
  "duration_mimg": 25.6,
  "tick_kimg": 12.8,
  "lr": 0.0001,
  "optim": "RAdam",
  "dropout": 0.2,
  "augment": 0.0,
  "q": 2.0,
  "double_ticks": 250,
  "ema_beta": 0.9999,
  "mapping": "sigmoid",
  "P_mean": -1.1,
  "P_std": 2.0,
  "k": 8.0,
  "b": 1.0,
  "c": 0.0,
  "metrics": ["fid50k_full"],
  "mid_t": [0.821],
  "launch": "bash run_ecm.sh <NGPUs> <PORT> --desc bs128.200k"
}
